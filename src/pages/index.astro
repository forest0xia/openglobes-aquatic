---
import { App } from '../components/App';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AquaticGlobe — 200,000+ aquatic species worldwide</title>
    <meta name="description" content="Interactive 3D globe showing 200,000+ aquatic species worldwide. Explore fish, mammals, cephalopods, reptiles, and more." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Loading screen styles — inlined so they render before any JS -->
    <style>
      #og-loading-screen {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #050a12;
        transition: opacity 0.4s ease-out;
      }
      #og-loading-screen.fade-out {
        opacity: 0;
        pointer-events: none;
      }
      #og-loading-title {
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        font-size: 28px;
        color: rgba(230, 240, 255, 0.95);
        margin-bottom: 8px;
        letter-spacing: -0.02em;
      }
      #og-loading-subtitle {
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        color: rgba(120, 140, 170, 0.5);
        margin-bottom: 32px;
      }
      #og-loading-track {
        width: 240px;
        height: 3px;
        background: rgba(76, 201, 240, 0.1);
        border-radius: 2px;
        overflow: hidden;
      }
      #og-loading-bar {
        width: 0%;
        height: 100%;
        background: #4cc9f0;
        border-radius: 2px;
        transition: width 0.3s ease-out;
      }
      #og-loading-pct {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: rgba(120, 140, 170, 0.5);
        margin-top: 12px;
      }
    </style>
  </head>
  <body>
    <!-- Loading screen — pure HTML, visible before any JS executes -->
    <div id="og-loading-screen">
      <div id="og-loading-title">AquaticGlobe</div>
      <div id="og-loading-subtitle">Loading ocean data&hellip;</div>
      <div id="og-loading-track">
        <div id="og-loading-bar"></div>
      </div>
      <div id="og-loading-pct">0%</div>
    </div>

    <App client:only="react" />

    <!-- Tiny inline script: listens to loadProgress and drives the bar.
         Must be is:inline so it executes immediately without Vite bundling. -->
    <script is:inline>
      (function () {
        var bar = document.getElementById('og-loading-bar');
        var pct = document.getElementById('og-loading-pct');
        var subtitle = document.getElementById('og-loading-subtitle');
        var screen = document.getElementById('og-loading-screen');
        if (!bar || !pct || !subtitle || !screen) return;

        function fadeOut() {
          screen.classList.add('fade-out');
          screen.addEventListener('transitionend', function () {
            screen.remove();
          }, { once: true });
        }

        // Poll for the loadProgress module (it loads with the React bundle)
        var poll = setInterval(function () {
          var lp = window.__ogLoadProgress;
          if (!lp) return;
          clearInterval(poll);

          lp.onProgress(function (progress, done, label) {
            var p = Math.round(progress * 100);
            bar.style.width = p + '%';
            pct.textContent = p + '%';
            if (label) subtitle.textContent = label;
            if (done) subtitle.textContent = 'Ready';

            if (done) {
              // Small delay so the user sees 100%
              setTimeout(fadeOut, 300);
            }
          });
        }, 50);

        // Safety fallback: remove loading screen after 10s regardless
        setTimeout(function () {
          clearInterval(poll);
          if (screen.parentNode) fadeOut();
        }, 10000);
      })();
    </script>
  </body>
</html>
